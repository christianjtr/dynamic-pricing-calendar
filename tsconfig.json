{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"allowSyntheticDefaultImports": true,
		"esModuleInterop": true,
		"jsx": "react-jsx",
		"allowJs": true,
		"checkJs": true,
		"noEmit": true,
		"types": ["vinxi/client"],
		"isolatedModules": true,
		"strict": true,
		"strictNullChecks": true,
		"noImplicitAny": true,
		"noUncheckedIndexedAccess": true,
		"paths": {
			"@shared/types": ["./shared/types"],
			"@shared/types/*": ["./shared/types/*"]
		}
	}
}
